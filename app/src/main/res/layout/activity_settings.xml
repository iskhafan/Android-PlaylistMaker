<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/settings_bg_color">

    <!--        NOTE: Manually select back arrow icon to follow the color of title text-->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/settings_bg_color"
        app:contentInsetStartWithNavigation="0dp"
        app:navigationIcon="@drawable/ic_title_back_btn_48"
        app:navigationIconTint="@color/settings_txt_color"
        app:title="@string/settings_scr_header"
        app:titleTextAppearance="@style/SettingsToolbarTitleAppearance"
        app:titleTextColor="@color/settings_txt_color"/>

<!--NOTE: Added extra gap between title and lower layout elements-->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/themeSwitcher"
        android:text="@string/settings_scr_theme_select_txt"
        style="@style/SettingsScreenRowsStyle"
        android:layout_marginTop="24dp"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/share_btn"
        android:text="@string/settings_scr_share_txt"
        android:drawableEnd="@drawable/ic_settings_share_btn_24"
        style="@style/SettingsScreenRowsStyle"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/support_btn"
        android:text="@string/settings_scr_support_txt"
        android:drawableEnd="@drawable/ic_settings_support_btn_24"
        style="@style/SettingsScreenRowsStyle"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/offert_btn"
        android:text="@string/settings_scr_offert_txt"
        android:drawableEnd="@drawable/ic_settings_fwd_btn_24"
        style="@style/SettingsScreenRowsStyle"/>

</LinearLayout>
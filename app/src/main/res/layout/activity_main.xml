<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_background_color"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/main_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:title="@string/main_scr_header"
        app:titleTextColor="@color/main_title_txt_color"
        app:titleTextAppearance="@style/MainToolbarTitleTextAppearance" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/search_btn"
            android:layout_marginBottom="@dimen/btn_margin_bottom"
            android:text="@string/main_scr_search_btn_txt"

            app:icon="@drawable/ic_search_btn_24"
            style="@style/MainScreenButtonStyle"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/library_btn"
            android:layout_marginBottom="@dimen/btn_margin_bottom"
            android:text="@string/main_scr_library_btn_txt"

            app:icon="@drawable/ic_library_btn_24"
            style="@style/MainScreenButtonStyle"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_btn"
            android:layout_marginBottom="@dimen/btn_margin_bottom"
            android:text="@string/main_scr_settings_btn_txt"

            app:icon="@drawable/ic_settings_btn_24"
            style="@style/MainScreenButtonStyle"/>

</LinearLayout>